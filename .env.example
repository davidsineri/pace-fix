# ============================================================
# PACE — Papua Creative Economy | Environment Variables
# ============================================================
# Salin file ini menjadi .env lalu isi semua nilai di bawah.
# JANGAN commit file .env ke Git (sudah ada di .gitignore).
# ============================================================

# Supabase — dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Midtrans — dapatkan dari: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# RajaOngkir — dapatkan dari: https://rajaongkir.com/akun
RAJAONGKIR_API_KEY=
RAJAONGKIR_ACCOUNT_TYPE=starter

# Gemini — dapatkan dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
